# aiNrve proxy runtime configuration

# HTTP listen port.
port: 8080

# Structured log level: debug|info|warn|error.
log_level: info

# Optional Postgres DSN for async request logging.
# If omitted, logs are printed to stdout.
database_url: ""

# Optional gateway auth key. If empty, auth middleware allows all requests.
ainrve_api_key: ""

# Seconds between provider health checks.
health_check_interval: 30

providers:
  openai:
    enabled: true
    # Prefer setting via OPENAI_API_KEY env var.
    api_key: ""
    base_url: https://api.openai.com
    # Provider preference weight used by the router.
    weight: 1.0

  anthropic:
    enabled: true
    api_key: ""
    base_url: https://api.anthropic.com
    weight: 1.0

  groq:
    enabled: true
    api_key: ""
    base_url: https://api.groq.com
    weight: 1.0

  together:
    enabled: true
    api_key: ""
    base_url: https://api.together.ai
    weight: 1.0

  gemini:
    enabled: true
    api_key: ""
    base_url: https://generativelanguage.googleapis.com
    weight: 1.0

routing:
  # Allowed strategies: cost|latency|balanced.
  default_strategy: balanced

  # Used by balanced strategy and as tie-breaker weights.
  weight_cost: 0.5
  weight_latency: 0.5

  # Optional task-specific forced provider mapping.
  task_overrides:
    classify: openai
    summarize: together
    code: groq
    rag: openai
    reasoning: anthropic

  # Provider to use if no healthy provider scores above zero.
  fallback_provider: openai
