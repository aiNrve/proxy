# Required provider API keys (set at least one)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
GEMINI_API_KEY=

# Optional runtime settings
AINRVE_API_KEY=
PORT=8080
LOG_LEVEL=info
HEALTH_CHECK_INTERVAL=30
CONFIG_PATH=./ainrve.yaml
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ainrve?sslmode=disable
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20
